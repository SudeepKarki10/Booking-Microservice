//used by my Node.js backend when the application is actually running and talking to the database.

generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma" // create @prisma folder inside node_modules and generate the client there
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL") -> new update for prisma requires the prisma.config.ts file to read env variables instead of the .env file directly. So we will remove this line and add it in the prisma.config.ts file
}

//this is where we will define our model schemas 

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String?
  emailVerified Boolean @default(false)
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  authProviders AuthProvider[]
}

enum Role {
  USER
  ADMIN
}


model AuthProvider{
  id String @id @default(uuid())
  provider String
  providerId String
  userId String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId]) // Ensure that the combination of provider and providerId is unique
  @@unique([userId, provider]) // Ensure that a user can only have one account per provider
  @@index([userId]) // Index for faster lookups by userId

}